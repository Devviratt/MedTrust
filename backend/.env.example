# Server
NODE_ENV=development
PORT=4000
API_VERSION=v1

# JWT — use strong random values in production: openssl rand -hex 64
JWT_SECRET=medtrust-dev-jwt-secret-min32chars!!
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=medtrust-dev-refresh-secret-32ch!
JWT_REFRESH_EXPIRES_IN=7d

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medtrust
DB_USER=medtrust_user
DB_PASSWORD=medtrust_secret
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_TTL=3600

# AI Microservices (gRPC) — use service hostnames when running in Docker
AI_VIDEO_SERVICE_URL=localhost:50051
AI_AUDIO_SERVICE_URL=localhost:50052
AI_BIOMETRIC_SERVICE_URL=localhost:50053

# Blockchain
BLOCKCHAIN_API_URL=http://localhost:8080
BLOCKCHAIN_CHANNEL=medtrust-channel
BLOCKCHAIN_CHAINCODE=medtrust-cc

# WebRTC / STUN
STUN_SERVER=stun:stun.l.google.com:19302

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
# Demo mode only: bypass role/permission/enrollment checks
RBAC_BYPASS=false
# CORS_ORIGIN: use http://localhost:3000 for Docker, http://localhost:5173 for Vite dev
CORS_ORIGIN=http://localhost:5173

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Logging
LOG_LEVEL=info
LOG_DIR=logs
